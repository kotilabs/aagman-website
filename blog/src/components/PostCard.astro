---
import { base, site } from '../config';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: string;
  tags: string[];
}

const { title, description, slug, pubDate, category, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card">
  <a class="card-link" href={`${base}/${slug}/`} aria-label={title}></a>
  <div class="card-meta">
    <span class="category">{category}</span>
    <span class="date">{formattedDate}</span>
  </div>
  <h2 class="card-title">{title}</h2>
  <p class="card-description">{description}</p>
  <div class="card-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</article>

<style>
  .post-card {
    position: relative;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    transition: border-color 0.2s, background 0.2s;
  }
  .post-card:hover {
    border-color: rgba(86, 232, 184, 0.25);
    background: var(--surface-2);
  }
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .card-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .category {
    color: var(--accent);
  }
  .card-title {
    margin: 0 0 10px;
    font-size: 22px;
    line-height: 1.25;
    color: var(--text);
    position: relative;
    z-index: 2;
  }
  .card-title:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .card-description {
    margin: 0 0 16px;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.6;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    position: relative;
    z-index: 2;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 8px;
    border-radius: 4px;
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid rgba(86, 232, 184, 0.18);
  }
</style>
