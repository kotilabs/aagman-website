---
import BaseLayout from './BaseLayout.astro';
import { base, site } from '../config';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  authorSlug: string;
  authorTitle?: string;
  category: string;
  tags: string[];
  ogImage?: string;
  canonical?: string;
}

const { title, description, slug, pubDate, updatedDate, author, authorSlug, authorTitle, category, tags, ogImage, canonical } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const breadcrumbs = [
  { name: 'Home', url: `${site}/` },
  { name: 'Blog', url: `${site}${base}/` },
  { name: title, url: `${site}${base}/${slug}/` },
];
---

<BaseLayout
  title={title}
  description={description}
  slug={slug}
  ogType="article"
  ogImage={ogImage}
  canonical={canonical}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
  authorSlug={authorSlug}
  authorTitle={authorTitle}
  tags={tags}
  breadcrumbs={breadcrumbs}
>
  <article class="post">
    <header class="post-header container">
      <div class="post-meta">
        <a class="category" href={`${base}/category/${category.toLowerCase().replace(/\s+/g, '-')}/`}>{category}</a>
        <span class="date">{formattedDate}</span>
        {updatedDate && <span class="updated">Updated {updatedDate.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
      </div>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
      <div class="author">
        <span class="author-name">By <a href={`${base}/author/${authorSlug}/`}>{author}</a></span>
        {authorTitle && <span class="author-title">{authorTitle}</span>}
      </div>
    </header>

    <div class="post-content container">
      <slot />
    </div>

    <footer class="post-footer container">
      <div class="tags">
        <span class="tags-label">Tags:</span>
        {tags.map(tag => <a class="tag" href={`${base}/category/${tag.toLowerCase().replace(/\s+/g, '-')}/`}>{tag}</a>)}
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding-top: 64px;
    padding-bottom: 48px;
    text-align: center;
  }
  .post-meta {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-dim);
    flex-wrap: wrap;
  }
  .category {
    color: var(--accent);
  }
  .category:hover {
    text-decoration: underline;
  }
  .post-header h1 {
    font-size: clamp(32px, 6vw, 52px);
    line-height: 1.1;
    margin: 0 0 20px;
    color: var(--text);
    font-weight: 700;
  }
  .post-description {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 auto 24px;
    line-height: 1.6;
  }
  .author {
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
    font-size: 14px;
    color: var(--text-muted);
    flex-wrap: wrap;
  }
  .author-name a {
    color: var(--text);
    font-weight: 500;
  }
  .author-title {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .post-content {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text);
  }
  .post-content :global(h2) {
    font-size: 28px;
    margin-top: 56px;
    margin-bottom: 20px;
    line-height: 1.25;
    color: var(--text);
  }
  .post-content :global(h3) {
    font-size: 22px;
    margin-top: 40px;
    margin-bottom: 16px;
    color: var(--text);
  }
  .post-content :global(p) {
    margin: 0 0 20px;
  }
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 24px;
    padding-left: 24px;
  }
  .post-content :global(li) {
    margin-bottom: 10px;
  }
  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-content :global(blockquote) {
    margin: 28px 0;
    padding: 20px 24px;
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 8px 8px 0;
    color: var(--text-muted);
  }
  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--surface-2);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent);
  }
  .post-content :global(pre) {
    background: var(--surface);
    padding: 20px;
    border-radius: var(--radius);
    overflow-x: auto;
    margin: 0 0 24px;
    border: 1px solid var(--border);
  }
  .post-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--text);
  }
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 24px;
    font-size: 15px;
  }
  .post-content :global(th),
  .post-content :global(td) {
    padding: 12px 16px;
    border: 1px solid var(--border);
    text-align: left;
  }
  .post-content :global(th) {
    background: var(--surface);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .post-footer {
    padding-top: 48px;
    padding-bottom: 24px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    font-size: 14px;
    color: var(--text-muted);
  }
  .tags-label {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 5px 10px;
    border-radius: 4px;
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid rgba(86, 232, 184, 0.18);
  }
  .tag:hover {
    text-decoration: none;
    background: rgba(86, 232, 184, 0.18);
  }
</style>
